{
    "swagger": "2.0",
    "info": {
        "description": "API para el manejo de entrenamientos.",
        "title": "Gestrym API Nutrition",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/gestrym-nutrition",
    "paths": {
        "/private/goals/calories": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Returns the user's stored calorie and macro targets with AI adjustment metadata.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "CalorieGoals"
                ],
                "summary": "Get current calorie goal",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            },
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Calculates TDEE using Mifflin-St Jeor + activity level and stores the result.\nactivityLevel: sedentary | light | moderate | active | very_active\nfitnessGoal:   lose_weight | maintain | gain_mass",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "CalorieGoals"
                ],
                "summary": "Set personalized calorie \u0026 macro targets",
                "parameters": [
                    {
                        "description": "Physical data + goal",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handlers.setGoalRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/private/goals/calories/adjust": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Fetches real weight metrics from progress-service and applies adaptive\ncalorie/macro adjustments based on the user's fitness goal and actual progress.\nThis is the AI integration endpoint — call it periodically (e.g. weekly).",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "CalorieGoals"
                ],
                "summary": "Auto-adjust calories from progress-service data",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/private/logs": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Returns totals, goals, and progress for a specific date.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "NutritionTracking"
                ],
                "summary": "Get daily nutrition summary",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Date (YYYY-MM-DD), defaults to today",
                        "name": "date",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            },
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Records a food item the user ate, calculates nutrition automatically.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "NutritionTracking"
                ],
                "summary": "Log food intake",
                "parameters": [
                    {
                        "description": "Food intake",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handlers.logFoodRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/private/logs/history": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Returns paginated nutrition logs within a date range.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "NutritionTracking"
                ],
                "summary": "Get nutrition history",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Start date (YYYY-MM-DD)",
                        "name": "start",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "End date (YYYY-MM-DD)",
                        "name": "end",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Page number (default 1)",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Page size (default 20, max 100)",
                        "name": "pageSize",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/private/meal-plans": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Creates a new meal plan for a user or as a template.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "MealPlans"
                ],
                "summary": "Create a meal plan",
                "parameters": [
                    {
                        "description": "Meal Plan Data",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/usecases.CreateMealPlanInput"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/private/meal-plans/user/{userId}": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Returns all meal plans assigned to a user.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "MealPlans"
                ],
                "summary": "Get meal plans for a user",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "User ID",
                        "name": "userId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/private/meal-plans/{id}": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Returns a meal plan with its days and items.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "MealPlans"
                ],
                "summary": "Get meal plan by ID",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Meal Plan ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/private/meal-plans/{id}/days": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Adds a new meal day to an existing meal plan.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "MealPlans"
                ],
                "summary": "Add a day to a meal plan",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Meal Plan ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Day data",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/usecases.AddMealDayInput"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/private/meal-plans/{id}/items": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Assigns a food item with quantity and meal type to a plan's day.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "MealPlans"
                ],
                "summary": "Add food item to a meal plan day",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Meal Plan ID (used for context)",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Item data",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/usecases.AddMealItemInput"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/public/foods": {
            "get": {
                "description": "Retrieve a list of foods filtered by name.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Nutrition"
                ],
                "summary": "Search foods",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Food name to search",
                        "name": "search",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/public/foods/import": {
            "post": {
                "description": "Triggers a one-time import of basic food categories from USDA API.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Nutrition"
                ],
                "summary": "Manual import of foods from USDA",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/public/foods/{id}": {
            "get": {
                "description": "Retrieve details of a specific food item.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Nutrition"
                ],
                "summary": "Get food by ID",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Food ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handlers.logFoodRequest": {
            "type": "object",
            "required": [
                "foodId",
                "quantity"
            ],
            "properties": {
                "date": {
                    "description": "\"YYYY-MM-DD\", optional",
                    "type": "string"
                },
                "foodId": {
                    "type": "integer"
                },
                "mealType": {
                    "$ref": "#/definitions/models.MealType"
                },
                "notes": {
                    "type": "string"
                },
                "quantity": {
                    "type": "number"
                }
            }
        },
        "handlers.setGoalRequest": {
            "type": "object",
            "required": [
                "ageYears",
                "heightCm",
                "weightKg"
            ],
            "properties": {
                "activityLevel": {
                    "$ref": "#/definitions/models.ActivityLevel"
                },
                "ageYears": {
                    "type": "integer"
                },
                "fitnessGoal": {
                    "$ref": "#/definitions/models.FitnessGoalType"
                },
                "heightCm": {
                    "type": "number"
                },
                "isMale": {
                    "type": "boolean"
                },
                "weightKg": {
                    "type": "number"
                }
            }
        },
        "models.ActivityLevel": {
            "type": "string",
            "enum": [
                "sedentary",
                "light",
                "moderate",
                "active",
                "very_active"
            ],
            "x-enum-comments": {
                "ActivityActive": "x1.725",
                "ActivityLight": "x1.375",
                "ActivityModerate": "x1.55",
                "ActivitySedentary": "x1.2",
                "ActivityVeryActive": "x1.9"
            },
            "x-enum-descriptions": [
                "x1.2",
                "x1.375",
                "x1.55",
                "x1.725",
                "x1.9"
            ],
            "x-enum-varnames": [
                "ActivitySedentary",
                "ActivityLight",
                "ActivityModerate",
                "ActivityActive",
                "ActivityVeryActive"
            ]
        },
        "models.FitnessGoalType": {
            "type": "string",
            "enum": [
                "lose_weight",
                "maintain",
                "gain_mass"
            ],
            "x-enum-comments": {
                "FitnessGoalGainMass": "surplus +500 kcal",
                "FitnessGoalLoseWeight": "deficit -500 kcal",
                "FitnessGoalMaintain": "TDEE"
            },
            "x-enum-descriptions": [
                "deficit -500 kcal",
                "TDEE",
                "surplus +500 kcal"
            ],
            "x-enum-varnames": [
                "FitnessGoalLoseWeight",
                "FitnessGoalMaintain",
                "FitnessGoalGainMass"
            ]
        },
        "models.MealType": {
            "type": "string",
            "enum": [
                "breakfast",
                "lunch",
                "dinner",
                "snack"
            ],
            "x-enum-varnames": [
                "MealTypeBreakfast",
                "MealTypeLunch",
                "MealTypeDinner",
                "MealTypeSnack"
            ]
        },
        "usecases.AddMealDayInput": {
            "type": "object",
            "properties": {
                "dayNumber": {
                    "type": "integer"
                },
                "mealPlanId": {
                    "type": "integer"
                }
            }
        },
        "usecases.AddMealItemInput": {
            "type": "object",
            "properties": {
                "foodId": {
                    "type": "integer"
                },
                "mealDayId": {
                    "type": "integer"
                },
                "mealType": {
                    "$ref": "#/definitions/models.MealType"
                },
                "quantity": {
                    "type": "number"
                }
            }
        },
        "usecases.CreateMealPlanInput": {
            "type": "object",
            "properties": {
                "createdBy": {
                    "type": "integer"
                },
                "durationDays": {
                    "type": "integer"
                },
                "goalCalories": {
                    "type": "number"
                },
                "goalCarbs": {
                    "type": "number"
                },
                "goalFats": {
                    "type": "number"
                },
                "goalProtein": {
                    "type": "number"
                },
                "isTemplate": {
                    "type": "boolean"
                },
                "name": {
                    "type": "string"
                },
                "userId": {
                    "type": "integer"
                }
            }
        }
    },
    "securityDefinitions": {
        "ApiKeyAuth": {
            "type": "apiKey",
            "name": "X-API-Key",
            "in": "header"
        },
        "BasicAuth": {
            "type": "basic"
        },
        "BearerAuth": {
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}